# autoweaver-lab deployment config.
#
# Copy to .env and edit AUTOWEAVER_REPO:
#   cp env.example .env
#
# Do not commit .env вЂ” it may hold a repo URL that resolves private credentials.

# в”Ђв”Ђ Private repo в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Prefer SSH + Deploy Key (see DEPLOYMENT_CONSENSUS.md В§"з§Ѓжњ‰д»“еє“и®їй—®ж–№ејЏ").
AUTOWEAVER_REPO=git@github.com:YOUR_ORG/autoweaver-lab.git

# в”Ђв”Ђ Host paths в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
AUTOWEAVER_BASE=$HOME/Documents/Github
AUTOWEAVER_MAIN_DIR=$AUTOWEAVER_BASE/autoweaver-lab
AUTOWEAVER_WORKTREES_DIR=$AUTOWEAVER_BASE/autoweaver-lab-worktrees
AUTOWEAVER_DATA_DIR=$AUTOWEAVER_BASE/autoweaver-data
AUTOWEAVER_CACHE_DIR=$AUTOWEAVER_DATA_DIR/cache

# в”Ђв”Ђ Active workdir (override per worktree) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Keep pointing to MAIN_DIR for main-branch work; flip to a worktree path
# when running an experiment branch.
AUTOWEAVER_WORKDIR=$AUTOWEAVER_MAIN_DIR
AUTOWEAVER_RUN_ID=main
COMPOSE_PROJECT_NAME=autoweaver_main

# в”Ђв”Ђ GPU pinning в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Leave blank to expose all GPUs via the nvidia runtime; set e.g. "0" or
# "0,1" to constrain a specific worktree to particular GPUs.
CUDA_VISIBLE_DEVICES=
